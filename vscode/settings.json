  "vim.leader": "<space>",
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.color": "rgba(255,255,0,0.4)",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "c", "c"],
      "commands": [
        "extension.changeCase.camel",
        {
          "command": "type",
          "args": { "text": "<Esc>" }
        }
      ]
    },
    {
      "before": ["<leader>", "c", "C"],
      "commands": [
        "extension.changeCase.constant",
        {
          "command": "type",
          "args": { "text": "<Esc>" }
        }
      ]
    },
    {
      "before": ["<leader>", "c", "s"],
      "commands": [
        "extension.changeCase.snake",
        {
          "command": "type",
          "args": { "text": "<Esc>" }
        }
      ]
    },
    {
      "before": ["<leader>", "c", "p"],
      "commands": [
        "extension.changeCase.pascal",
        {
          "command": "type",
          "args": { "text": "<Esc>" }
        }
      ]
    },
    {
      "before": ["<leader>", "d"],
      "after": ["o", "<ESC>"],
      "commands": [
        {
          "command": "editor.action.insertSnippet",
          "args": {
            "snippet": "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}"
          }
        }
      ]
    },
    {
      "before": ["z", "E"],
      "commands": ["editor.unfoldAll"]
    },
    {
      "before": ["<C-u>"],
      "after": ["1", "2", "g", "k"]
    },
    {
      "before": ["<C-d>"],
      "after": ["1", "2", "g", "j"]
    },
    {
      "before": ["<C-n>"],
      "after": [
        "o",
        "#",
        " ",
        "n",
        "o",
        "c",
        "h",
        "e",
        "c",
        "k",
        "i",
        "n",
        "<ESC>"
      ]
    },
    {
      "before": ["<leader>", "r"],
      "after": ["o", "r", "e", "t", "u", "r", "n", "<ESC>"]
    },
    {
      "before": ["<leader>", "c"],
      "after": ["o", "c", "o", "n", "t", "i", "n", "u", "e", "<ESC>"]
    },
    {
      "before": ["<leader>", "b"],
      "after": ["o", "b", "r", "e", "a", "k", "<ESC>"]
    },
    {
      "before": ["j"],
      "after": ["g", "j"]
    },
    {
      "before": ["<Esc>"],
      "commands": ["removeSecondaryCursors"],
      "after": ["<Esc>"]
    },
    {
      "before": ["k"],
      "after": ["g", "k"]
    },
    {
      "before": ["$"],
      "after": ["$"],
      "commands": ["editor.unfold"]
    },
    {
      "before": ["^"],
      "after": ["^"],
      "commands": ["editor.unfold"]
    },
    {
      "before": ["0"],
      "after": ["0"],
      "commands": ["editor.unfold"]
    },
    {
      "before": ["l"],
      "after": ["l"],
      "commands": ["editor.unfold"]
    },
    {
      "before": ["<C-j>"],
      "after": ["}"]
    },
    {
      "before": ["<C-k>"],
      "after": ["{"]
    },
    {
      "before": ["<leader>", "0"],
      "commands": [
        "editor.foldLevel3",
        "editor.foldLevel2",
        "editor.foldLevel1"
      ]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": ["J"],
      "commands": ["editor.action.moveLinesDownAction"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.moveLinesUpAction"]
    },
    {
      "before": ["<leader>", "c", "c"],
      "commands": [
        "extension.changeCase.camel",
        {
          "command": "type",
          "args": { "text": "<Esc>" }
        }
