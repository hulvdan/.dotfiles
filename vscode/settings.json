  "editor.foldingStrategy": "auto",
  "editor.defaultFoldingRangeProvider": "zokugun.explicit-folding",
  "explicitFolding.rules": {
    "*": {
      "begin": "##",
      "end": "##"
    }
  },
  "[python]": {
    "explicitFolding.rules": [
      {
        "begin": "##",
        "end": "##"
      },
      {
        "begin": "cog]]]",
        "end": "[[[end]]]"
      }
    ]
  },
  "[proto]": {
    "explicitFolding.rules": [
      {
        "begin": "message",
        "end": "}"
      },
      {
        "begin": "cog]]]",
        "end": "[[[end]]]"
      }
    ]
  },
  "[cpp]": {
    "explicitFolding.rules": [
      {
        "begin": "///",
        "end": "///"
      },
      {
        "begin": "cog]]]",
        "end": "[[[end]]]"
      }
    ]
  },
  "explicitFolding.notification": "none",
