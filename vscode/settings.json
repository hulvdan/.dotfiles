  "workbench.secondarySideBar.showLabels": false,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "vim.vimrc.enable": true,
  "redhat.telemetry.enabled": false,
  "workbench.activityBar.location": "top",
  "explorer.confirmDelete": false,
  "diffEditor.renderSideBySide": false,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": false,
  "window.title": "${rootName}${separator}${profileName}${separator}${appName}",
  "lldb.suppressUpdateNotifications": true,
  "[gdscript]": {
    "editor.codeLens": false,
    "editor.defaultFormatter": null,
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false,
    "editor.formatOnType": false
  },
  "vim.leader": "<space>",
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.color": "rgba(255,255,0,0.4)",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["z", "E"],
      "commands": ["editor.unfoldAll"]
    },
    {
      "before": ["<C-u>"],
      "after": ["1", "2", "g", "k"]
    },
    {
      "before": ["<C-d>"],
      "after": ["1", "2", "g", "j"]
    },
    {
      "before": ["<C-n>"],
      "after": [
        "o",
        "#",
        " ",
        "n",
        "o",
        "c",
        "h",
        "e",
        "c",
        "k",
        "i",
        "n",
        "<ESC>"
      ]
    },
    {
      "before": ["<leader>", "c"],
      "after": ["o", "c", "o", "n", "t", "i", "n", "u", "e", "<ESC>"]
    },
    {
      "before": ["<leader>", "b"],
      "after": ["o", "b", "r", "e", "a", "k", "<ESC>"]
    },
    {
      "before": ["j"],
      "after": ["g", "j"]
    },
    {
      "before": ["<Esc>"],
      "commands": ["removeSecondaryCursors"],
      "after": ["<Esc>"]
    },
    {
      "before": ["k"],
      "after": ["g", "k"]
    },
    {
      "before": ["$"],
      "after": ["$"],
      "commands": ["editor.unfold"]
    },
    {
      "before": ["^"],
      "after": ["^"],
      "commands": ["editor.unfold"]
    },
    {
      "before": ["0"],
      "after": ["0"],
      "commands": ["editor.unfold"]
    },
    {
      "before": ["l"],
      "after": ["l"],
      "commands": ["editor.unfold"]
    },
    {
      "before": ["<C-j>"],
      "after": ["}"]
    },
    {
      "before": ["<C-k>"],
      "after": ["{"]
    },
    {
      "before": ["<leader>", "0"],
      "commands": [
        "editor.foldLevel3",
        "editor.foldLevel2",
        "editor.foldLevel1"
      ]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": ["J"],
      "commands": ["editor.action.moveLinesDownAction"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.moveLinesUpAction"]
    }
  ],
  "json.format.enable": false,
  "workbench.editor.showIcons": false,
  "workbench.editor.tabSizing": "shrink",
  "chat.fontSize": 12,
  "editor.foldingStrategy": "auto",
  "editor.defaultFoldingRangeProvider": "zokugun.explicit-folding",
  "explicitFolding.rules": {
    "*": {
      "begin": "##",
      "end": "##"
    }
  },
  "[python]": {
    "explicitFolding.rules": [
      {
        "begin": "##",
        "end": "##"
      },
      {
        "begin": "cog]]]",
        "end": "[[[end]]]"
      }
    ]
  },
  "[proto]": {
    "explicitFolding.rules": [
      {
        "begin": "message",
        "end": "}"
      },
      {
        "begin": "cog]]]",
        "end": "[[[end]]]"
      }
    ]
  },
  "explicitFolding.notification": "none",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": ["comment", "punctuation.definition.comment"],
        "settings": {
          "foreground": "#dc9824",
          "fontStyle": ""
        }
      }
    ]
  },
  "godotTools.inlayHints.gdscript": true,
  "window.openFoldersInNewWindow": "on",
  "debug.onTaskErrors": "showErrors",
  "workbench.editor.enablePreview": false,
  "extensions.ignoreRecommendations": true,
  "workbench.activityBar.compact": true,
  "window.menuBarVisibility": "toggle",
  "chat.disableAIFeatures": true,
  "workbench.notifications.showInTitleBar": false,
